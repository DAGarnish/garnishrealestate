generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactEnquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  origin    String?
  location  String?
  budget    String?
  timeline  String?
  message   String?
  createdAt DateTime @default(now())
}
